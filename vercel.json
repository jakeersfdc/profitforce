{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["bom1"],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/ml-api/:path*",
      "destination": "https://ml-api.profitforce.app/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/broker/profitforce/cron",
      "schedule": "0 4 * * *"
    }
  ]
}
