# Example environment variables for production/local compose
# Copy to .env (do not commit secrets to git)

# App
NODE_ENV=production
NEXT_PUBLIC_API_BASE=/api

# Database (Postgres)
DATABASE_URL=postgresql://bf:bfpass@db:5432/ProfitForce

# Inference service
INFERENCE_URL=http://ml:8000

# Secrets (set real values in production)
ALPACA_KEY=
ALPACA_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SENTRY_DSN=

# Mobile / API tokens (comma-separated). Example: "token1,token2"
API_TOKENS=
# Allowed CORS origins (comma-separated). Use '*' to allow all during testing.
ALLOWED_ORIGINS=*
INFERENCE_JWT_SECRET=

# Google Cloud (for deploy workflow)
GCLOUD_PROJECT=
GCP_REGION=us-central1
GCLOUD_SA_KEY=
INFERENCE_SERVICE_TOKEN=

# Clerk auth (frontend + backend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
ALLOW_PUBLIC_TRAIN=0
ALLOW_PUBLIC_BACKTEST=0
# Optional
PYTHON_CMD=.venv\Scripts\python.exe
