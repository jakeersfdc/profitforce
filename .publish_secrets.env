# Copy to .publish_secrets.env and replace the placeholders (no extra quotes)
# After filling, run the bulk upload from the repo root:
# Get-Content .publish_secrets.env | ForEach-Object { if ($_ -and $_ -match '^\s*([^=]+)=(.*)$') { gh secret set $matches[1].Trim() --body $matches[2].Trim() } }

# Required / semi-required secrets - REPLACE the values below with your real secrets:
DATABASE_URL=postgres://<DB_USER>:<DB_PASS>@<DB_HOST>:5432/<DB_NAME>
JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
CLERK_SECRET_KEY=sk_test_CHANGE_ME
CLERK_PUBLISHABLE_KEY=pk_test_CHANGE_ME
# For GCLOUD_SERVICE_KEY you can either paste the entire JSON as a single-line value
# or set it separately using: gh secret set GCLOUD_SERVICE_KEY --body "$(Get-Content -Raw 'C:\path\to\service-account.json')"
GCLOUD_SERVICE_KEY=CHANGE_ME_GCLOUD_SERVICE_KEY
EXPO_TOKEN=EXPO_TOKEN_CHANGE_ME

# Optional / envs for other workflows:
NEXT_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_ORIGIN=https://ProfitForce-signal
NEXT_PUBLIC_MOBILE_SCHEME=ProfitForce-signal
SENTRY_DSN=CHANGE_ME_SENTRY_DSN
GCLOUD_PROJECT=CHANGE_ME_GCLOUD_PROJECT

# Notes:
# - Do NOT commit real secrets to the repo. This file is intended for local use before
#   uploading values to GitHub Actions secrets via `gh secret set` (or for temporary local testing).
# - After replacing placeholders, run the bulk upload command shown above from the repo root.
ADMIN_USERS=jakeersfdc@gmail.com
