# Copy to .publish_secrets.env and fill values (no quotes)
# Then run the bulk upload from the repo root:
# Get-Content .publish_secrets.env | ForEach-Object { if ($_ -and $_ -match '^\s*([^=]+)=(.*)$') { gh secret set $matches[1].Trim() --body $matches[2].Trim() } }

# Required/semi-required secrets (fill what you have):
