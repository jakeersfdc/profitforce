CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
GCLOUD_SERVICE_KEY="" # paste full JSON on one line or set via file method below
EXPO_TOKEN=

# Optional / envs for other workflows:
NEXT_PUBLIC_URL=
SENTRY_DSN=
